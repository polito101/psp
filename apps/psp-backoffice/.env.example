# Copiar a .env.local y rellenar valores reales (no commitear secretos).

# `merchant`: /login solo merchant. `admin`: /admin/login solo admin (suele ser otro deploy).
BACKOFFICE_PORTAL_MODE=merchant
NEXT_PUBLIC_BACKOFFICE_PORTAL_MODE=merchant

PSP_API_BASE_URL=http://localhost:3003
# Opcional: ms máximos del fetch servidor→psp-api (default 60000). Bajar en local si quieres fallar antes cuando la API no está levantada.
# PSP_API_PROXY_TIMEOUT_MS=60000
PSP_INTERNAL_API_SECRET=change-me-in-production
BACKOFFICE_ADMIN_SECRET=change-me-in-production2
# Firma JWT de sesión (debe ser distinto de BACKOFFICE_ADMIN_SECRET y PSP_INTERNAL_API_SECRET).
BACKOFFICE_SESSION_JWT_SECRET=change-me-session-jwt-secret-32chars
# Login merchant: token `expUnix:hexHmac` (HMAC de `merchantId.expUnix`; distinto de PSP_INTERNAL_API_SECRET).
BACKOFFICE_MERCHANT_PORTAL_SECRET=change-me-merchant-portal-hmac
NEXT_PUBLIC_TRANSACTIONS_REFRESH_MS=15000

# Onboarding merchant (CRM): MERCHANT_ONBOARDING_BASE_URL en psp-api debe coincidir con la URL publica
# de este deploy + ruta `/onboarding/[token]` (ver BACKOFFICE_CONTEXT.md y docs/crm-status.md).
# Solo si un proxy de confianza controla X-Forwarded-For / X-Real-IP en el borde (Nginx, ALB, etc.).
# Sin esto, esas cabeceras se ignoran para el rate limit de login (evita spoof y DoS dirigido a otra IP).
# TRUST_X_FORWARDED_FOR=false
# Cabeceras x-vercel-forwarded-for / cf-connecting-ip: por defecto se ignoran fuera de runtime Vercel
# (VERCEL=1) o Cloudflare Pages (CF_PAGES=1). En self-hosted detrás de CF orange-cloud u otro borde,
# activar explícitamente (o usar flags separados si solo aplica una plataforma):
# TRUST_PLATFORM_IP_HEADERS=true
# TRUST_VERCEL_IP_HEADERS=true
# TRUST_CLOUDFLARE_IP_HEADERS=true
