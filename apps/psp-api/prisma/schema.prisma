generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id                      String    @id @default(cuid())
  name                    String
  apiKeyHash              String    @map("api_key_hash")
  apiKeyExpiresAt         DateTime? @map("api_key_expires_at")
  apiKeyRevokedAt         DateTime? @map("api_key_revoked_at")
  webhookUrl              String?   @map("webhook_url")
  webhookSecretCiphertext String    @map("webhook_secret_ciphertext")
  feeBps                  Int       @default(290) @map("fee_bps")
  createdAt               DateTime  @default(now()) @map("created_at")

  paymentLinks PaymentLink[]
  payments     Payment[]
  ledgerLines  LedgerLine[]
  webhooks     WebhookDelivery[]
}

model PaymentLink {
  id          String    @id @default(cuid())
  merchantId  String    @map("merchant_id")
  slug        String    @unique
  amountMinor Int       @map("amount_minor")
  currency    String    @default("EUR")
  expiresAt   DateTime? @map("expires_at")
  metadata    Json?
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([merchantId])
}

model Payment {
  id             String   @id @default(cuid())
  merchantId     String   @map("merchant_id")
  paymentLinkId  String?  @map("payment_link_id")
  idempotencyKey String?  @map("idempotency_key")
  amountMinor    Int      @map("amount_minor")
  currency       String
  status         String
  statusReason   String?  @map("status_reason")
  selectedProvider String? @map("selected_provider")
  providerRef    String?  @map("provider_ref")
  rail           String   @default("fiat")
  lastAttemptAt  DateTime? @map("last_attempt_at")
  succeededAt    DateTime? @map("succeeded_at")
  failedAt       DateTime? @map("failed_at")
  canceledAt     DateTime? @map("canceled_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  paymentLink   PaymentLink?   @relation(fields: [paymentLinkId], references: [id], onDelete: SetNull)
  ledgerLines   LedgerLine[]
  attempts      PaymentAttempt[]
  operations    PaymentOperation[]

  @@unique([merchantId, idempotencyKey])
  @@index([merchantId, status])
  @@index([merchantId, selectedProvider])
}

model PaymentOperation {
  id            String   @id @default(cuid())
  paymentId     String   @map("payment_id")
  merchantId    String   @map("merchant_id")
  operation     String
  payloadHash   String   @map("payload_hash")
  status        String   @default("processing")
  processingAt  DateTime @default(now()) @map("processing_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, operation])
  @@index([merchantId, createdAt])
  @@index([status, processingAt])
}

model PaymentAttempt {
  id                String   @id @default(cuid())
  paymentId         String   @map("payment_id")
  merchantId        String   @map("merchant_id")
  operation         String
  provider          String
  attemptNo         Int      @map("attempt_no")
  status            String
  providerPaymentId String?  @map("provider_payment_id")
  errorCode         String?  @map("error_code")
  errorMessage      String?  @map("error_message")
  latencyMs         Int?     @map("latency_ms")
  requestPayload    Json?    @map("request_payload")
  responsePayload   Json?    @map("response_payload")
  createdAt         DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([merchantId, createdAt])
  @@index([provider, providerPaymentId])
  @@unique([paymentId, operation, attemptNo])
}

model LedgerLine {
  id          String   @id @default(cuid())
  merchantId  String   @map("merchant_id")
  paymentId   String?  @map("payment_id")
  entryType   String   @map("entry_type")
  amountMinor Int      @map("amount_minor")
  currency    String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([merchantId, createdAt])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  merchantId  String   @map("merchant_id")
  eventType   String   @map("event_type")
  payload     Json
  status      String   @default("pending")
  attempts    Int      @default(0)
  lastError   String?  @map("last_error")
  scheduledAt DateTime @default(now()) @map("scheduled_at")
  createdAt   DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, status])
  @@index([status, scheduledAt])
}
