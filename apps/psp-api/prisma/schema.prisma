generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum SettlementMode {
  NET
  GROSS
}

enum PayoutScheduleType {
  T_PLUS_N
  WEEKLY
}

enum SettlementStatus {
  PENDING
  AVAILABLE
  PAID
  REVERSED
}

enum PayoutStatus {
  CREATED
  SENT
  FAILED
}

enum SettlementRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELED
}

enum MerchantOnboardingStatus {
  ACCOUNT_CREATED
  DOCUMENTATION_PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  ACTIVE
}

enum MerchantOnboardingChecklistStatus {
  PENDING
  COMPLETED
  BLOCKED
}

enum MerchantOnboardingActorType {
  SYSTEM
  MERCHANT
  ADMIN
}

enum MerchantRegistrationStatus {
  LEAD
  IN_REVIEW
  APPROVED
  REJECTED
  ACTIVE
}

enum MerchantIndustry {
  CLOUD_COMPUTING
  CRYPTO
  FOREX
  GAMBLING
  PSP
  OTHER
}

enum ProviderLogOperation {
  CREATE
}

enum DynamicPaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum PaymentChannel {
  CASH
  ONLINE
  CREDIT_CARD
  CRYPTO
}

enum PaymentIntegrationMode {
  S2S
  REDIRECTION
  HOSTED_PAGE
}

enum PaymentProviderRequestTemplate {
  REDIRECT_SIMPLE
  SPEI_BANK_TRANSFER
}

model Merchant {
  id                         String                     @id @default(cuid())
  name                       String
  email                      String?                    @unique @db.VarChar(320)
  contactName                String?                    @map("contact_name") @db.VarChar(160)
  contactPhone               String?                    @map("contact_phone") @db.VarChar(64)
  websiteUrl                 String?                    @map("website_url") @db.VarChar(2048)
  mid                        String                     @unique @db.VarChar(16)
  registrationNumber         String?                    @map("registration_number") @db.VarChar(64)
  registrationStatus         MerchantRegistrationStatus @default(LEAD) @map("registration_status")
  industry                   MerchantIndustry           @default(OTHER)
  apiKeyHash                 String                     @map("api_key_hash")
  apiKeyExpiresAt            DateTime?                  @map("api_key_expires_at")
  apiKeyRevokedAt            DateTime?                  @map("api_key_revoked_at")
  webhookUrl                 String?                    @map("webhook_url")
  webhookSecretCiphertext    String                     @map("webhook_secret_ciphertext")
  feeBps                     Int                        @default(290) @map("fee_bps")
  isActive                   Boolean                    @default(true) @map("is_active")
  deactivatedAt              DateTime?                  @map("deactivated_at")
  merchantPortalPasswordHash String?                    @map("merchant_portal_password_hash")
  createdAt                  DateTime                   @default(now()) @map("created_at")

  paymentLinks            PaymentLink[]
  payments                Payment[]
  ledgerLines             LedgerLine[]
  webhooks                WebhookDelivery[]
  rateTables              MerchantRateTable[]
  feeQuotes               PaymentFeeQuote[]
  settlements             PaymentSettlement[]
  payouts                 Payout[]
  merchantPaymentMethods  MerchantPaymentMethod[]
  settlementRequests      SettlementRequest[]
  onboardingApplications  MerchantOnboardingApplication[]
  merchantProviderRates   MerchantProviderRate[]
}

model PaymentLink {
  id          String    @id @default(cuid())
  merchantId  String    @map("merchant_id")
  slug        String    @unique
  amountMinor Int       @map("amount_minor")
  currency    String    @default("EUR")
  expiresAt   DateTime? @map("expires_at")
  metadata    Json?
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([merchantId])
}

model Payment {
  id             String   @id @default(cuid())
  merchantId     String   @map("merchant_id")
  paymentLinkId  String?  @map("payment_link_id")
  idempotencyKey String?  @map("idempotency_key")
  /// SHA-256 hex de `hashCreatePaymentIntentPayload` al crear (idempotencia del payload de create).
  createPayloadHash String? @map("create_payload_hash")
  amountMinor    Int      @map("amount_minor")
  currency       String
  status         String
  statusReason   String?  @map("status_reason")
  selectedProvider String? @map("selected_provider")
  providerRef    String?  @map("provider_ref")
  rail           String   @default("fiat")
  /// ISO 3166-1 alpha-2 (opcional) — país del pagador para reporting ops.
  payerCountry         String?  @map("payer_country") @db.VarChar(2)
  /// Código de método de pago del catálogo (`PaymentMethodDefinition.code`), p. ej. mock_card.
  paymentMethodCode    String?  @map("payment_method_code") @db.VarChar(64)
  /// Familia de instrumento (card, transfer, wallet, …) para filtros agregados.
  paymentMethodFamily  String?  @map("payment_method_family") @db.VarChar(32)
  /// Día de la semana UTC de `created_at` (0=domingo … 6=sábado), denormalizado para filtros ops.
  createdWeekdayUtc Int? @map("created_weekday_utc")
  lastAttemptAt  DateTime? @map("last_attempt_at")
  succeededAt    DateTime? @map("succeeded_at")
  failedAt       DateTime? @map("failed_at")
  canceledAt     DateTime? @map("canceled_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  /// URL de notificación al comercio (pagos dinámicos / webhooks salientes por pago).
  notificationUrl String?  @map("notification_url") @db.VarChar(2048)
  /// Snapshot JSON de la acción mostrable al pagador (p. ej. redirect o datos SPEI); sin usar como única fuente de secretos.
  actionSnapshot  Json?    @map("action_snapshot")

  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  paymentLink   PaymentLink?   @relation(fields: [paymentLinkId], references: [id], onDelete: SetNull)
  ledgerLines   LedgerLine[]
  feeQuote      PaymentFeeQuote?
  settlement    PaymentSettlement?
  attempts      PaymentAttempt[]
  operations    PaymentOperation[]
  providerLogs              ProviderLog[]
  notificationDeliveries    PaymentNotificationDelivery[]

  @@unique([merchantId, idempotencyKey])
  @@index([merchantId, status])
  @@index([merchantId, selectedProvider])
  // Acceso operativo (ops/transactions): orden estable por createdAt/id y filtros globales sin merchantId.
  @@index([createdAt, id])
  @@index([status, createdAt, id])
  // Serie volumen horario ops (status + currency + rango en succeeded_at).
  @@index([status, currency, succeededAt], map: "Payment_status_currency_succeeded_at_idx")
  @@index([selectedProvider, createdAt, id])
  @@index([merchantId, createdAt, id])
  @@index([selectedProvider, providerRef])
  @@index([payerCountry, createdAt])
  @@index([paymentMethodCode, createdAt])
  @@index([createdWeekdayUtc, createdAt], map: "Payment_created_weekday_utc_created_at_idx")
}

/// Catálogo global de métodos de pago (arranque provider-based: mock_card, mock_transfer).
model PaymentMethodDefinition {
  id         String   @id @default(cuid())
  code       String   @unique @db.VarChar(64)
  label      String
  /// Debe alinearse con `PaymentProviderName` cuando aplique (mock, acme).
  provider   String   @db.VarChar(32)
  category   String   @db.VarChar(32)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  merchantMethods MerchantPaymentMethod[]

  @@index([provider, active])
}

/// Configuración por merchant: kill switch, límites y visibilidad.
model MerchantPaymentMethod {
  id                   String   @id @default(cuid())
  merchantId           String   @map("merchant_id")
  definitionId         String   @map("definition_id")
  /// Habilitado por el comercio (kill switch merchant).
  merchantEnabled      Boolean  @default(true) @map("merchant_enabled")
  /// Habilitado por plataforma/admin.
  adminEnabled         Boolean  @default(true) @map("admin_enabled")
  minAmountMinor       Int?     @map("min_amount_minor")
  maxAmountMinor       Int?     @map("max_amount_minor")
  visibleToMerchant    Boolean  @default(true) @map("visible_to_merchant")
  lastChangedBy        String?  @map("last_changed_by") @db.VarChar(128)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  merchant   Merchant               @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  definition PaymentMethodDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([merchantId, definitionId])
  @@index([merchantId, merchantEnabled, adminEnabled])
}

model PaymentProviderConfig {
  id                    String   @id @default(cuid())
  name                  String   @db.VarChar(160)
  description           String?  @db.VarChar(512)
  integrationBaseUrl    String   @map("integration_base_url") @db.VarChar(2048)
  initPaymentResource   String   @map("init_payment_resource") @db.VarChar(2048)
  isConfigured          Boolean  @default(false) @map("is_configured")
  isActive              Boolean  @default(true) @map("is_active")
  isPublished           Boolean  @default(false) @map("is_published")
  configCiphertext      String?  @map("config_ciphertext")
  credentialsCiphertext String?  @map("credentials_ciphertext")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  routes         PaymentMethodRoute[]
  merchantRates  MerchantProviderRate[]

  @@index([isActive, isPublished])
  @@map("payment_provider_configs")
}

model PaymentMethodRoute {
  id                    String                         @id @default(cuid())
  providerId            String                         @map("provider_id")
  methodCode            String                         @map("method_code") @db.VarChar(64)
  methodName            String                         @map("method_name") @db.VarChar(160)
  countryCode           String                         @map("country_code") @db.VarChar(2)
  countryName           String?                        @map("country_name") @db.VarChar(120)
  countryImageName      String?                        @map("country_image_name") @db.VarChar(120)
  channel               PaymentChannel
  integrationMode       PaymentIntegrationMode         @map("integration_mode")
  requestTemplate       PaymentProviderRequestTemplate @map("request_template")
  integrationCode       String?                        @map("integration_code") @db.VarChar(120)
  checkoutUrlTemplate   String?                        @map("checkout_url_template") @db.VarChar(2048)
  expirationTimeOffset  Int                            @default(0) @map("expiration_time_offset")
  weight                Int                            @default(0)
  isActive              Boolean                        @default(true) @map("is_active")
  isPublished           Boolean                        @default(false) @map("is_published")
  isFlagged             Boolean                        @default(false) @map("is_flagged")
  forcePendingInput     Boolean                        @default(false) @map("force_pending_input")
  isVirtual             Boolean                        @default(false) @map("is_virtual")
  riskEvaluation        Boolean                        @default(false) @map("risk_evaluation")
  routeConfigJson       Json?                          @map("route_config_json")
  routeConfigCiphertext String?                        @map("route_config_ciphertext")
  createdAt             DateTime                       @default(now()) @map("created_at")
  updatedAt             DateTime                       @updatedAt @map("updated_at")

  provider   PaymentProviderConfig        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  currencies PaymentMethodRouteCurrency[]

  @@index([countryCode, channel, isActive, isPublished])
  @@index([providerId, countryCode])
  @@index([methodCode, countryCode, channel])
  @@map("payment_method_routes")
}

model PaymentMethodRouteCurrency {
  id        String   @id @default(cuid())
  routeId   String   @map("route_id")
  currency  String   @db.VarChar(8)
  minAmount Decimal  @map("min_amount") @db.Decimal(18, 6)
  maxAmount Decimal  @map("max_amount") @db.Decimal(18, 6)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  route PaymentMethodRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, currency])
  @@index([currency])
  @@map("payment_method_route_currencies")
}

model MerchantProviderRate {
  id                        String   @id @default(cuid())
  merchantId                String   @map("merchant_id")
  providerId                String   @map("provider_id")
  countryCode               String   @map("country_code") @db.VarChar(2)
  percentage                Decimal  @db.Decimal(10, 4)
  fixed                     Decimal  @db.Decimal(18, 6)
  minRateDiscount           Decimal  @default(0) @map("min_rate_discount") @db.Decimal(18, 6)
  applyToCustomer           Boolean  @default(false) @map("apply_to_customer")
  fxSpread                  Decimal  @default(0) @map("fx_spread") @db.Decimal(10, 4)
  fxMarkup                  Decimal  @default(0) @map("fx_markup") @db.Decimal(10, 4)
  disableIndustryValidation Boolean  @default(false) @map("disable_industry_validation")
  cashEnabled               Boolean  @default(true) @map("cash_enabled")
  creditCardEnabled         Boolean  @default(true) @map("credit_card_enabled")
  cryptoEnabled             Boolean  @default(true) @map("crypto_enabled")
  onlineEnabled             Boolean  @default(true) @map("online_enabled")
  cashMinAmount             Decimal  @default(0) @map("cash_min_amount") @db.Decimal(18, 6)
  creditCardMinAmount       Decimal  @default(0) @map("credit_card_min_amount") @db.Decimal(18, 6)
  cryptoMinAmount           Decimal  @default(0) @map("crypto_min_amount") @db.Decimal(18, 6)
  onlineMinAmount           Decimal  @default(0) @map("online_min_amount") @db.Decimal(18, 6)
  isActive                  Boolean  @default(true) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  merchant Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  provider PaymentProviderConfig @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([merchantId, providerId, countryCode])
  @@index([merchantId, countryCode, isActive])
  @@map("merchant_provider_rates")
}

/// Solicitud manual de liquidación/payout (workflow backoffice).
model SettlementRequest {
  id                  String                  @id @default(cuid())
  merchantId          String                  @map("merchant_id")
  currency            String                  @db.VarChar(8)
  requestedNetMinor   Int                     @map("requested_net_minor")
  status              SettlementRequestStatus @default(PENDING)
  payoutId            String?                 @unique @map("payout_id")
  /// Suma del net minor liquidado en esta aprobación (puede abarcar varios payouts).
  paidNetMinor        Int?                    @map("paid_net_minor")
  /// false si quedó saldo AVAILABLE tras el flujo (p. ej. tope de iteraciones o nuevo capture concurrente).
  settledAllAvailable Boolean                 @default(true) @map("settled_all_available")
  notes               String?                 @db.Text
  requestedByRole     String                  @map("requested_by_role") @db.VarChar(16)
  reviewedNotes       String?                 @map("reviewed_notes") @db.Text
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  /// Payout ancla (p. ej. el último de una serie); el resto enlaza por `Payout.settlementRequestId`.
  payout              Payout?                 @relation("SettlementRequestAnchorPayout", fields: [payoutId], references: [id], onDelete: SetNull)
  payoutsFromApproval Payout[]                @relation("PayoutFromSettlementRequest")

  @@index([merchantId, status, createdAt])
  @@index([status, createdAt])
}

/// Snapshot de tipo de cambio para reporting auditable (base → quote, p. ej. EUR→USD).
model FxRateSnapshot {
  id             String   @id @default(cuid())
  baseCurrency   String   @map("base_currency") @db.VarChar(8)
  quoteCurrency  String   @map("quote_currency") @db.VarChar(8)
  /// Tasa: 1 base = rateDecimal quote (Prisma Decimal).
  rateDecimal    Decimal  @map("rate_decimal") @db.Decimal(28, 14)
  effectiveAt    DateTime @map("effective_at")
  source         String   @db.VarChar(64)
  externalRef    String?  @map("external_ref") @db.VarChar(256)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([baseCurrency, quoteCurrency, effectiveAt])
}

// `merchantId` debe coincidir con `Payment.merchantId` del mismo `paymentId`; el servicio valida ownership antes del lock y purga filas incoherentes en `claimPaymentOperation`.
model PaymentOperation {
  id            String   @id @default(cuid())
  paymentId     String   @map("payment_id")
  merchantId    String   @map("merchant_id")
  operation     String
  payloadHash   String   @map("payload_hash")
  status        String   @default("processing")
  processingAt  DateTime @default(now()) @map("processing_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, operation])
  @@index([merchantId, createdAt])
  @@index([status, processingAt])
}

model PaymentAttempt {
  id                String   @id @default(cuid())
  paymentId         String   @map("payment_id")
  merchantId        String   @map("merchant_id")
  operation         String
  provider          String
  attemptNo         Int      @map("attempt_no")
  status            String
  providerPaymentId String?  @map("provider_payment_id")
  errorCode         String?  @map("error_code")
  errorMessage      String?  @map("error_message")
  latencyMs         Int?     @map("latency_ms")
  requestPayload    Json?    @map("request_payload")
  responsePayload   Json?    @map("response_payload")
  createdAt         DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([merchantId, createdAt])
  @@index([provider, providerPaymentId])
  @@unique([paymentId, operation, attemptNo])
}

model ProviderLog {
  id                    String               @id @default(cuid())
  paymentId             String               @map("payment_id")
  providerId            String               @map("provider_id")
  routeId               String               @map("route_id")
  operation             ProviderLogOperation
  createdAt             DateTime             @default(now()) @map("created_at")
  httpStatus            Int?                 @map("http_status")
  latencyMs             Int?                 @map("latency_ms")
  providerTransactionId String?              @map("provider_transaction_id") @db.VarChar(160)
  requestMasked         Json?                @map("request_masked")
  requestCiphertext     String?              @map("request_ciphertext")
  responseMasked        Json?                @map("response_masked")
  responseCiphertext    String?              @map("response_ciphertext")
  errorCode             String?              @map("error_code") @db.VarChar(120)
  errorMessage          String?              @map("error_message") @db.VarChar(512)

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("ProviderLog")
}

model PaymentNotificationDelivery {
  id                     String               @id @default(cuid())
  paymentId              String               @map("payment_id")
  statusSnapshot         DynamicPaymentStatus @map("status_snapshot")
  createdAt              DateTime             @default(now()) @map("created_at")
  httpStatus             Int?                 @map("http_status")
  requestBodyMasked      Json?                @map("request_body_masked")
  requestBodyCiphertext  String?              @map("request_body_ciphertext")
  responseBodyMasked     Json?                @map("response_body_masked")
  responseBodyCiphertext String?              @map("response_body_ciphertext")
  attemptNo              Int                  @map("attempt_no")
  isResend               Boolean              @default(false) @map("is_resend")
  originalDeliveryId     String?              @map("original_delivery_id")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, attemptNo])
  @@index([paymentId, createdAt])
  @@map("PaymentNotificationDelivery")
}

model MerchantRateTable {
  id                  String            @id @default(cuid())
  merchantId          String            @map("merchant_id")
  currency            String
  /// Debe coincidir con un valor de PaymentProviderName (mock, acme).
  provider            String
  percentageBps       Int               @map("percentage_bps")
  fixedMinor          Int               @default(0) @map("fixed_minor")
  minimumMinor        Int               @default(0) @map("minimum_minor")
  settlementMode      SettlementMode    @default(NET) @map("settlement_mode")
  payoutScheduleType  PayoutScheduleType @default(T_PLUS_N) @map("payout_schedule_type")
  payoutScheduleParam Int               @default(1) @map("payout_schedule_param")
  contractRef         String?           @map("contract_ref")
  activeFrom          DateTime          @default(now()) @map("active_from")
  activeTo            DateTime?         @map("active_to")
  createdAt           DateTime          @default(now()) @map("created_at")

  merchant  Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  feeQuotes PaymentFeeQuote[]

  // Arranque / comprobación de proveedor: equality por `provider` (no encaja el índice [merchantId,…]).
  @@index([provider, merchantId, currency])
  @@index([merchantId, currency, provider, activeFrom])
}

model PaymentFeeQuote {
  id             String         @id @default(cuid())
  /// FK a `Payment.id` (1:1). En listados ops se filtra por prefijo (`startsWith`) sobre esta columna, no con `contains`/`ilike` sobre `Payment`.
  paymentId      String         @unique @map("payment_id")
  merchantId     String         @map("merchant_id")
  rateTableId    String         @map("rate_table_id")
  /// Snapshot del proveedor que liquidó el pago (provider del rate table aplicado).
  provider       String
  currency       String
  percentageBps  Int            @map("percentage_bps")
  fixedMinor     Int            @map("fixed_minor")
  minimumMinor   Int            @map("minimum_minor")
  grossMinor     Int            @map("gross_minor")
  feeMinor       Int            @map("fee_minor")
  netMinor       Int            @map("net_minor")
  settlementMode SettlementMode @map("settlement_mode")
  createdAt      DateTime       @default(now()) @map("created_at")

  payment   Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  merchant  Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  rateTable MerchantRateTable @relation(fields: [rateTableId], references: [id])

  @@index([merchantId, createdAt])
  @@index([provider, createdAt])
}

model PaymentSettlement {
  id             String           @id @default(cuid())
  paymentId       String           @unique @map("payment_id")
  merchantId      String           @map("merchant_id")
  currency        String
  provider        String
  settlementMode  SettlementMode   @map("settlement_mode")
  status          SettlementStatus @default(PENDING)
  grossMinor      Int              @map("gross_minor")
  feeMinor        Int              @map("fee_minor")
  netMinor        Int              @map("net_minor")
  capturedAt      DateTime         @map("captured_at")
  availableAt     DateTime         @map("available_at")
  paidAt          DateTime?        @map("paid_at")
  payoutId        String?          @map("payout_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  payment    Payment    @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  merchant   Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payout     Payout?    @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  payoutItem PayoutItem?

  // Guardrails y consultas filtrando por proveedor.
  @@index([provider])
  @@index([merchantId, currency, status, availableAt])
  @@index([payoutId])
}

model Payout {
  id           String       @id @default(cuid())
  merchantId    String       @map("merchant_id")
  currency      String
  status        PayoutStatus @default(CREATED)
  windowStartAt DateTime     @map("window_start_at")
  windowEndAt   DateTime     @map("window_end_at")
  grossMinor    Int          @map("gross_minor")
  feeMinor      Int          @map("fee_minor")
  netMinor      Int          @map("net_minor")
  createdAt     DateTime     @default(now()) @map("created_at")
  /// Solicitud cuya aprobación generó este payout (puede haber varios payouts por solicitud).
  settlementRequestId String? @map("settlement_request_id")

  merchant            Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  items               PayoutItem[]
  settlements         PaymentSettlement[]
  settlementRequestAnchor SettlementRequest? @relation("SettlementRequestAnchorPayout")
  settlementRequestFromApproval SettlementRequest? @relation("PayoutFromSettlementRequest", fields: [settlementRequestId], references: [id], onDelete: SetNull)

  @@index([merchantId, createdAt])
  @@index([settlementRequestId])
}

model PayoutItem {
  id                  String   @id @default(cuid())
  payoutId            String   @map("payout_id")
  paymentSettlementId String   @unique @map("payment_settlement_id")
  grossMinor          Int      @map("gross_minor")
  feeMinor            Int      @map("fee_minor")
  netMinor            Int      @map("net_minor")
  createdAt           DateTime @default(now()) @map("created_at")

  payout            Payout            @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  paymentSettlement PaymentSettlement @relation(fields: [paymentSettlementId], references: [id], onDelete: Cascade)

  @@index([payoutId, createdAt])
}

model LedgerLine {
  id          String   @id @default(cuid())
  merchantId  String   @map("merchant_id")
  paymentId   String?  @map("payment_id")
  entryType   String   @map("entry_type")
  amountMinor Int      @map("amount_minor")
  currency    String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([merchantId, createdAt])
  // getBalances(): groupBy currency+entryType con where merchantId + entryType IN (...)
  @@index([merchantId, entryType, currency])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  merchantId  String   @map("merchant_id")
  eventType   String   @map("event_type")
  payload     Json
  status      String   @default("pending")
  attempts    Int      @default(0)
  lastError   String?  @map("last_error")
  scheduledAt DateTime @default(now()) @map("scheduled_at")
  createdAt   DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, status])
  @@index([status, scheduledAt])
}

model MerchantOnboardingApplication {
  id              String                   @id @default(cuid())
  merchantId      String                   @map("merchant_id")
  status          MerchantOnboardingStatus @default(ACCOUNT_CREATED)
  contactName     String                   @map("contact_name") @db.VarChar(160)
  /// Email normalizado (lower+trim) en creación; unicidad DB evita carreras en `createApplication`.
  contactEmail    String                   @unique @map("contact_email") @db.VarChar(320)
  contactPhone    String                   @map("contact_phone") @db.VarChar(64)
  tradeName       String?                  @map("trade_name") @db.VarChar(160)
  legalName       String?                  @map("legal_name") @db.VarChar(200)
  country         String?                  @db.VarChar(2)
  website         String?                  @db.VarChar(2048)
  businessType    String?                  @map("business_type") @db.VarChar(120)
  rejectionReason String?                  @map("rejection_reason") @db.Text
  submittedAt     DateTime?                @map("submitted_at")
  reviewedAt      DateTime?                @map("reviewed_at")
  approvedAt      DateTime?                @map("approved_at")
  rejectedAt      DateTime?                @map("rejected_at")
  activatedAt     DateTime?                @map("activated_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  merchant       Merchant                            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  checklistItems MerchantOnboardingChecklistItem[]
  events         MerchantOnboardingEvent[]
  tokens         MerchantOnboardingToken[]

  @@index([status, createdAt])
  @@index([merchantId])
  @@map("merchant_onboarding_applications")
}

model MerchantOnboardingChecklistItem {
  id              String                            @id @default(cuid())
  applicationId   String                            @map("application_id")
  key             String                            @db.VarChar(80)
  label           String                            @db.VarChar(160)
  status          MerchantOnboardingChecklistStatus @default(PENDING)
  completedAt     DateTime?                         @map("completed_at")
  createdAt       DateTime                          @default(now()) @map("created_at")
  updatedAt       DateTime                          @updatedAt @map("updated_at")

  application MerchantOnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, key])
  @@index([applicationId, status])
  @@map("merchant_onboarding_checklist_items")
}

model MerchantOnboardingEvent {
  id            String                      @id @default(cuid())
  applicationId String                      @map("application_id")
  type          String                      @db.VarChar(80)
  actorType     MerchantOnboardingActorType @map("actor_type")
  actorId       String?                     @map("actor_id") @db.VarChar(160)
  message       String                      @db.Text
  metadata      Json?
  createdAt     DateTime                    @default(now()) @map("created_at")

  application MerchantOnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
  @@index([type, createdAt])
  @@map("merchant_onboarding_events")
}

model MerchantOnboardingToken {
  id            String    @id @default(cuid())
  applicationId String    @map("application_id")
  tokenHash     String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt     DateTime  @map("expires_at")
  usedAt        DateTime? @map("used_at")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  application MerchantOnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
  @@index([expiresAt])
  @@map("merchant_onboarding_tokens")
}
