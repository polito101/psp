NODE_ENV="sandbox"

# Base de datos (docker-compose: postgres://psp:psp_dev_password@localhost:5432/psp)
DATABASE_URL="postgresql://psp:psp_dev_password@localhost:5432/psp?schema=public"

# Redis (obligatorio para sandbox estable)
REDIS_URL="redis://localhost:6379"

# Secreto interno para POST /merchants (bootstrap)
# IMPORTANTE: cámbialo antes de compartir entorno. Debe ser aleatorio y largo.
INTERNAL_API_SECRET="replace-with-random-long-secret"

# Cifrado de secretos de webhook en reposo (mínimo 32 caracteres)
# IMPORTANTE: usa una clave aleatoria de 32+ caracteres.
APP_ENCRYPTION_KEY="replace-with-random-32-plus-chars"

PORT=3000
ENABLE_SWAGGER="true"
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Log por petición HTTP (JSON). En producción el default validado es solo errores (4xx/5xx).
# Valores: off | all | errors | sample
# HTTP_LOG_MODE=
# Tasa 0–1 si HTTP_LOG_MODE=sample (default 0.1)
# HTTP_LOG_SAMPLE_RATE=0.1
# Prefijos de ruta separados por coma (ej. webhooks de alto QPS). En sandbox/production
# se añade siempre /api/v1/pay además de lo indicado aquí.
# HTTP_LOG_SKIP_PATH_PREFIXES=/api/v1/webhooks

# Opcional: Stripe test (conector fiat)
STRIPE_SECRET_KEY=
# Reservado para inbound webhook Stripe (actualmente no consumido por el backend).
# STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE_URL="https://api.stripe.com/v1"

# Payments Orchestrator V2
# Lista CSV de merchants habilitados (usa * para habilitar todos en sandbox)
PAYMENTS_V2_ENABLED_MERCHANTS="*"
# Orden de fallback de proveedores
PAYMENTS_PROVIDER_ORDER="stripe,mock"
# Seguridad: "mock" solo recomendado en sandbox/dev. En producción, por defecto el orden es "stripe".
# Si necesitas permitir "mock" fuera de sandbox/dev, exige un flag explícito:
# PAYMENTS_ALLOW_MOCK="true"
# Resiliencia proveedor
PAYMENTS_PROVIDER_TIMEOUT_MS=8000
PAYMENTS_PROVIDER_MAX_RETRIES=2
PAYMENTS_PROVIDER_CB_FAILURES=3
PAYMENTS_PROVIDER_CB_COOLDOWN_MS=60000

# Worker de entregas webhook (cola en DB). Desactiva en réplicas API sin worker dedicado.
# WEBHOOK_WORKER_ENABLED=true

# Crypto MVP (Polygon USDT)
CRYPTO_RPC_URL=
CRYPTO_USDT_ADDRESS=

