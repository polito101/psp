# Copiar a .env.local en local (opcional si usas URLs por defecto de Render sandbox).
NEXT_PUBLIC_MERCHANT_BACKOFFICE_URL=https://psp-backoffice.onrender.com/login

# URL base pública de psp-api (sin path final). Usada solo en servidor por la ruta
# `POST /api/merchant-onboarding` para proxy a `POST /api/v1/merchant-onboarding/applications`.
PSP_API_BASE_URL=https://psp-api.onrender.com
