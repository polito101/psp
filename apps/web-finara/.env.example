# Copiar a .env.local en local (opcional si usas URLs por defecto de Render sandbox).
NEXT_PUBLIC_MERCHANT_BACKOFFICE_URL=https://psp-backoffice.onrender.com/login

# Proxy servidor → psp-api (onboarding público). En local: http://localhost:3000 (o el puerto de la API).
PSP_API_BASE_URL=http://localhost:3000
# Opcional: timeout ms del fetch hacia la API (solo dígitos; default 10000, máx. 120000).
# PSP_API_PROXY_TIMEOUT_MS=60000

# Detrás de un proxy que controla X-Forwarded-For (p. ej. Render): ya cubierto con RENDER=true en hosting.
# En otro reverse proxy sin RENDER: TRUST_X_FORWARDED_FOR=true
